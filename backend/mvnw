# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.3.2
# ----------------------------------------------------------------------------

set -e

# Find the project base dir, i.e. the directory that contains the folder ".mvn".
find_maven_basedir() {
  if [ -z "$1" ]; then
    echo "Path not specified to find_maven_basedir" 1>&2
    return 1
  fi

  basedir="$1"
  wdir="$1"
  while [ "$wdir" != '/' ]; do
    if [ -d "$wdir"/.mvn ]; then
      basedir=$wdir
      break
    fi
    if [ -d "${wdir}" ]; then
      wdir=$(cd "$wdir/.." && pwd)
    fi
  done
  printf '%s' "$(cd "$basedir" || exit; pwd)"
}

# concatenates all lines of a file
concat_lines() {
  if [ -f "$1" ]; then
    tr -s '\r\n' ' ' <"$1"
  fi
}

log() {
  if [ "$MVNW_VERBOSE" = true ]; then
    printf '%s\n' "$1"
  fi
}

BASE_DIR=$(find_maven_basedir "$(dirname "$0")")
if [ -z "$BASE_DIR" ]; then
  exit 1
fi

MAVEN_PROJECTBASEDIR=${MAVEN_BASEDIR:-"$BASE_DIR"}
log "$MAVEN_PROJECTBASEDIR"

# OS specific support.
cygwin=false
darwin=false
mingw=false
case "$(uname)" in
  CYGWIN*)  cygwin=true  ;;
  MINGW*)   mingw=true   ;;
  Darwin*)  darwin=true  ;;
esac

# For Cygwin and MinGW, ensure paths are in Unix format before anything is touched.
if $cygwin; then
  [ -n "$JAVA_HOME" ] && JAVA_HOME=$(cygpath --unix "$JAVA_HOME")
  [ -n "$CLASSPATH" ] && CLASSPATH=$(cygpath --path --unix "$CLASSPATH")
fi

# Detect JAVA_HOME
if [ -z "$JAVA_HOME" ]; then
  if $darwin; then
    # macOS: use java_home helper if available
    if [ -x /usr/libexec/java_home ]; then
      JAVA_HOME=$(/usr/libexec/java_home 2>/dev/null) || true
    fi
  fi
fi

if [ -z "$JAVA_HOME" ]; then
  # Try to detect from the java binary on PATH
  javaExecutable="$(command -v javac 2>/dev/null || true)"
  if [ -n "$javaExecutable" ]; then
    if $darwin; then
      javaExecutable="$(readlink "$javaExecutable" 2>/dev/null || echo "$javaExecutable")"
      JAVA_HOME="$(echo "$javaExecutable" | sed 's%/bin/javac%%')"
    else
      JAVA_HOME="$(readlink -f "$javaExecutable" 2>/dev/null | sed 's%/bin/javac%%')"
    fi
    export JAVA_HOME
  fi
fi

# Set JAVACMD
if [ -z "$JAVACMD" ]; then
  if [ -n "$JAVA_HOME" ]; then
    if [ -x "$JAVA_HOME/jre/sh/java" ]; then
      JAVACMD="$JAVA_HOME/jre/sh/java"
    else
      JAVACMD="$JAVA_HOME/bin/java"
    fi
  else
    JAVACMD="$(command -v java 2>/dev/null || echo java)"
  fi
fi

if [ ! -x "$JAVACMD" ]; then
  echo "Error: JAVA_HOME is not defined correctly." >&2
  echo "  Cannot execute: $JAVACMD" >&2
  echo "  Please set JAVA_HOME or ensure java is on your PATH." >&2
  exit 1
fi

log "Using Java from: $JAVACMD"

##########################################################################################
# Download maven-wrapper.jar if not present
##########################################################################################
wrapperJarPath="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
if [ -r "$wrapperJarPath" ]; then
  log "Found $wrapperJarPath"
else
  log "Downloading maven-wrapper.jar ..."

  wrapperUrl="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"

  while IFS="=" read -r key value; do
    key=$(echo "$key" | tr -d '\r')
    case "$key" in
      wrapperUrl) wrapperUrl="$value"; break ;;
    esac
  done <"$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

  log "Downloading from: $wrapperUrl"

  if command -v wget >/dev/null 2>&1; then
    wget -q -O "$wrapperJarPath" "$wrapperUrl"
  elif command -v curl >/dev/null 2>&1; then
    curl -fsSL -o "$wrapperJarPath" "$wrapperUrl"
  else
    echo "Error: neither wget nor curl is available to download maven-wrapper.jar" >&2
    exit 1
  fi
fi
##########################################################################################
# End of download
##########################################################################################

MAVEN_OPTS="$(concat_lines "$MAVEN_PROJECTBASEDIR/.mvn/jvm.config") $MAVEN_OPTS"

MAVEN_CMD_LINE_ARGS="$MAVEN_CONFIG $*"
export MAVEN_CMD_LINE_ARGS

WRAPPER_LAUNCHER=org.apache.maven.wrapper.MavenWrapperMain

exec "$JAVACMD" \
  $MAVEN_OPTS \
  $MAVEN_DEBUG_OPTS \
  -classpath "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar" \
  "-Dmaven.multiModuleProjectDirectory=${MAVEN_PROJECTBASEDIR}" \
  ${WRAPPER_LAUNCHER} $MAVEN_CONFIG "$@"
